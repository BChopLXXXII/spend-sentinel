# SpendSentinel environment variables

# Demo mode is ON by default.
# Set to false to forward requests to Anthropic API for real responses.
SPEND_SENTINEL_DEMO_MODE=true

# Path for persistent local state (keys, budgets, logs, settings).
# Use a mounted volume in production.
SPEND_SENTINEL_DATA_FILE=./data/spend-store.json

# HTTP Basic Auth for dashboard + API.
# Required in production; optional for local dev.
SPEND_SENTINEL_ADMIN_USER=admin
SPEND_SENTINEL_ADMIN_PASS=change-me-now

# Optional: disable automatic demo key seeding in development.
# SPEND_SENTINEL_SEED_DEMO_KEY=false
